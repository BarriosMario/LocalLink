<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LocalLink.Login.RegisterPage"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             Shell.TabBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource BgLight}, Dark={StaticResource BgDark}}">

    <Grid>
        <Image Source="{AppThemeBinding Light='gradientbg.png', Dark='darkbg.png'}" 
               Aspect="AspectFill"
               HorizontalOptions="Center" 
               VerticalOptions="Center"
               Opacity="0.5" />

        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="25" Spacing="15">

                <VerticalStackLayout Spacing="5" Margin="0,20,0,10">
                    <Label Text="LocalLink" 
                           FontSize="48" 
                           TextColor="{AppThemeBinding Light={StaticResource AccentLight}, Dark={StaticResource AccentDark}}" 
                           HorizontalOptions="Center" />

                    <Label Text="Únete a la comunidad de LocalLink. Crea tu perfil gratis y empieza a descubrir o vender productos en tu zona hoy mismo."
                           TextColor="{AppThemeBinding Light={StaticResource TitleLight}, Dark={StaticResource TitleDark}}"
                           FontSize="15"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15">
                    <Border HeightRequest="60"
                            StrokeThickness="0"
                            Opacity="0.7"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light={StaticResource BgLight}, Dark={StaticResource BgDark}}">
                        <Entry x:Name="EmailEntry"
                               TextChanged="OnNoSpacesTextChanged"
                               Placeholder="Correo electrónico" 
                               PlaceholderColor="Gray" 
                               BackgroundColor="Transparent"
                               TextColor="{AppThemeBinding Light={StaticResource TitleLight}, Dark={StaticResource TitleDark}}" 
                               VerticalOptions="Center" 
                               Margin="15,0"
                               Keyboard="Email"/>
                    </Border>

                    <Border HeightRequest="60"
                            StrokeThickness="0"
                            Opacity="0.7"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light={StaticResource BgLight}, Dark={StaticResource BgDark}}">
                        <Entry x:Name="UsernameEntry"
                               TextChanged="OnNoSpacesTextChanged"
                               Placeholder="Nombre de usuario" 
                               PlaceholderColor="Gray" 
                               BackgroundColor="Transparent"
                               TextColor="{AppThemeBinding Light={StaticResource TitleLight}, Dark={StaticResource TitleDark}}" 
                               VerticalOptions="Center" 
                               Margin="15,0"/>
                    </Border>

                    <Border HeightRequest="60"
                            StrokeThickness="0"
                            Opacity="0.7"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light={StaticResource BgLight}, Dark={StaticResource BgDark}}">
                        <Grid ColumnDefinitions="*, Auto">
                            <Entry x:Name="PassEntry1" 
                                   IsPassword="True" 
                                   Placeholder="Contraseña"
                                   TextChanged="OnPasswordChanged"
                                   PlaceholderColor="Gray" 
                                   BackgroundColor="Transparent"
                                   TextColor="{AppThemeBinding Light={StaticResource TitleLight}, Dark={StaticResource TitleDark}}" 
                                   VerticalOptions="Center"
                                   Margin="15,0"/>
                            <ImageButton x:Name="BtnEye1"
                                         Grid.Column="1" 
                                         Source="eye_off_icon.png" 
                                         HeightRequest="25" 
                                         WidthRequest="25" 
                                         Margin="0,0,10,0"
                                         BackgroundColor="Transparent"
                                         Clicked="OnShowPasswordClicked"/>
                        </Grid>
                    </Border>

                    <Border HeightRequest="60"
                            StrokeThickness="0"
                            Opacity="0.7"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light={StaticResource BgLight}, Dark={StaticResource BgDark}}">
                        <Grid ColumnDefinitions="*, Auto">
                            <Entry x:Name="PassEntry2" 
                                   IsPassword="True" 
                                   Placeholder="Confirmar contraseña" 
                                   TextChanged="OnPasswordChanged"
                                   PlaceholderColor="Gray" 
                                   BackgroundColor="Transparent"
                                   TextColor="{AppThemeBinding Light={StaticResource TitleLight}, Dark={StaticResource TitleDark}}" 
                                   VerticalOptions="Center"
                                   Margin="15,0"/>
                            <ImageButton x:Name="BtnEye2"
                                         Grid.Column="1" 
                                         Source="eye_off_icon.png" 
                                         HeightRequest="25" 
                                         WidthRequest="25" 
                                         Margin="0,0,10,0"
                                         BackgroundColor="Transparent"
                                         Clicked="OnShowPasswordClicked"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6" Margin="5,5,0,0">
                    <HorizontalStackLayout Spacing="8">
                        <BoxView x:Name="ReqLength" WidthRequest="12" HeightRequest="12" CornerRadius="6" BackgroundColor="White" VerticalOptions="Center"/>
                        <Label Text="Mínimo 10 caracteres" TextColor="{AppThemeBinding Light={StaticResource TitleLight}, Dark={StaticResource TitleDark}}" FontSize="13"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8">
                        <BoxView x:Name="ReqLower" WidthRequest="12" HeightRequest="12" CornerRadius="6" BackgroundColor="White" VerticalOptions="Center"/>
                        <Label Text="Al menos una letra minúscula" TextColor="{AppThemeBinding Light={StaticResource TitleLight}, Dark={StaticResource TitleDark}}" FontSize="13"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8">
                        <BoxView x:Name="ReqUpper" WidthRequest="12" HeightRequest="12" CornerRadius="6" BackgroundColor="White" VerticalOptions="Center"/>
                        <Label Text="Al menos una letra mayúscula" TextColor="{AppThemeBinding Light={StaticResource TitleLight}, Dark={StaticResource TitleDark}}" FontSize="13"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8">
                        <BoxView x:Name="ReqNumber" WidthRequest="12" HeightRequest="12" CornerRadius="6" BackgroundColor="White" VerticalOptions="Center"/>
                        <Label Text="Al menos un número" TextColor="{AppThemeBinding Light={StaticResource TitleLight}, Dark={StaticResource TitleDark}}" FontSize="13"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8">
                        <BoxView x:Name="ReqSymbol" WidthRequest="12" HeightRequest="12" CornerRadius="6" BackgroundColor="White" VerticalOptions="Center"/>
                        <Label Text="Al menos un símbolo" TextColor="{AppThemeBinding Light={StaticResource TitleLight}, Dark={StaticResource TitleDark}}" FontSize="13"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8">
                        <BoxView x:Name="ReqMatch" WidthRequest="12" HeightRequest="12" CornerRadius="6" BackgroundColor="White" VerticalOptions="Center"/>
                        <Label Text="Las contraseñas deben coincidir" TextColor="{AppThemeBinding Light={StaticResource TitleLight}, Dark={StaticResource TitleDark}}" FontSize="13"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
                
                <VerticalStackLayout Spacing="10" Margin="0,10,0,0">
                    <Button x:Name="RegisterButton"  
                            Text="Registrarse"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light={StaticResource BtnTextLight}, Dark={StaticResource BtnTextDark}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource BtnLight}, Dark={StaticResource BtnDark}}"
                            HeightRequest="55"
                            CornerRadius="10"
                            Clicked="OnRegisterClicked" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="0,5,0,0">
                        <CheckBox x:Name="TermsCheckBox"
                                  Grid.Column="0"
                                  Color="{AppThemeBinding Light={StaticResource AccentLight}, Dark={StaticResource AccentDark}}"
                                  VerticalOptions="Start"/>

                        <Label Grid.Column="1" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource TitleLight}, Dark={StaticResource TitleDark}}" LineBreakMode="WordWrap" VerticalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Al registrarte, aceptas nuestros " />
                                    <Span Text="Términos y Condiciones" TextColor="{AppThemeBinding Light={StaticResource AccentLight}, Dark={StaticResource AccentDark}}" FontAttributes="Bold">
                                        <Span.GestureRecognizers><TapGestureRecognizer Tapped="OpenTermsAndConditions" /></Span.GestureRecognizers>
                                    </Span>
                                    <Span Text=" y la " />
                                    <Span Text="Política de Privacidad" TextColor="{AppThemeBinding Light={StaticResource AccentLight}, Dark={StaticResource AccentDark}}" FontAttributes="Bold">
                                        <Span.GestureRecognizers><TapGestureRecognizer Tapped="OpenPrivacyPolicy" /></Span.GestureRecognizers>
                                    </Span>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Margin="0,0,0,10">
                    <BoxView HeightRequest="0.5" BackgroundColor="Gray" Opacity="0.3" Margin="0,10,0,10"/>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                        <Label Text="¿Ya tienes una cuenta?" TextColor="{AppThemeBinding Light={StaticResource TitleLight}, Dark={StaticResource TitleDark}}" FontSize="15" VerticalOptions="Center"/>
                        <Button Text="Iniciar sesión" 
                                TextColor="{AppThemeBinding Light={StaticResource AccentLight}, Dark={StaticResource AccentDark}}" 
                                BackgroundColor="Transparent" FontSize="15" FontAttributes="Bold" Padding="0" Clicked="OnLoginClicked"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
