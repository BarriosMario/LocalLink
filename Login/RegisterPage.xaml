<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LocalLink.Login.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{AppThemeBinding Light={StaticResource BgLight},
                                      Dark={StaticResource BgDark}}"
    NavigationPage.HasNavigationBar="False"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <Grid>
        <Image
            Aspect="AspectFill"
            Opacity="0.5"
            Source="{AppThemeBinding Light='gradientbg.png',
                                     Dark='darkbg.png'}" />
        <ScrollView VerticalOptions="{OnPlatform Android=Center, WinUI=Fill}" VerticalScrollBarVisibility="{OnPlatform Android=Never, WinUI=Auto}">
            <VerticalStackLayout Padding="25" Spacing="15">

                <VerticalStackLayout Margin="0,20,0,10" Spacing="5">
                    <Image
                        HeightRequest="250"
                        HorizontalOptions="Center"
                        Source="{AppThemeBinding Light='logolp.png',
                                                 Dark='logolpd.png'}"
                        WidthRequest="250" />

                    <Label
                        FontSize="15"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="WordWrap"
                        Text="Únete a la comunidad de LocalLink. Crea tu perfil gratis y empieza a descubrir o vender productos en tu zona hoy mismo."
                        TextColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                    Dark={StaticResource TitleDark}}" />
                </VerticalStackLayout>


                <VerticalStackLayout Spacing="15">
                    <Border
                        Padding="2,10"
                        BackgroundColor="{AppThemeBinding Light={StaticResource BgLight},
                                                          Dark={StaticResource BgDark}}"
                        HeightRequest="60"
                        Opacity="0.7"
                        Stroke="{AppThemeBinding Light={StaticResource BgDark},
                                      Dark={StaticResource BgLight}}"
                        StrokeThickness="2">
                        <Grid ColumnDefinitions="*, Auto">
                            <Entry
                                x:Name="EmailEntry"
                                Keyboard="Email"
                                Placeholder="Correo electrónico"
                                PlaceholderColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                                   Dark={StaticResource TitleDark}}"
                                TextChanged="OnNoSpacesTextChanged"
                                TextColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                            Dark={StaticResource TitleDark}}"
                                VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Border
                        Padding="2,10"
                        BackgroundColor="{AppThemeBinding Light={StaticResource BgLight},
                                                          Dark={StaticResource BgDark}}"
                        HeightRequest="60"
                        Opacity="0.7"
                        Stroke="{AppThemeBinding Light={StaticResource BgDark},
                                      Dark={StaticResource BgLight}}"
                        StrokeThickness="2">
                        <Grid ColumnDefinitions="*, Auto">
                            <Entry
                                x:Name="UsernameEntry"
                                Placeholder="Nombre de usuario"
                                PlaceholderColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                                   Dark={StaticResource TitleDark}}"
                                TextChanged="OnNoSpacesTextChanged"
                                TextColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                            Dark={StaticResource TitleDark}}"
                                VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Border
                        Padding="2,10"
                        BackgroundColor="{AppThemeBinding Light={StaticResource BgLight},
                                                          Dark={StaticResource BgDark}}"
                        HeightRequest="60"
                        Opacity="0.7"
                        Stroke="{AppThemeBinding Light={StaticResource BgDark},
                                      Dark={StaticResource BgLight}}"
                        StrokeThickness="2">
                        <Grid ColumnDefinitions="*, Auto">

                            <Entry
                                x:Name="PassEntry1"
                                IsPassword="True"
                                Placeholder="Contraseña"
                                PlaceholderColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                                   Dark={StaticResource TitleDark}}"
                                TextChanged="OnPasswordChanged"
                                TextColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                            Dark={StaticResource TitleDark}}"
                                VerticalOptions="Center" />
                            <ImageButton
                                x:Name="BtnEye1"
                                Grid.Column="1"
                                BackgroundColor="Transparent"
                                Clicked="OnShowPasswordClicked"
                                HeightRequest="25"
                                Source="eye_icon.png"
                                WidthRequest="25" />
                        </Grid>
                    </Border>

                    <Border
                        Padding="2,10"
                        BackgroundColor="{AppThemeBinding Light={StaticResource BgLight},
                                                          Dark={StaticResource BgDark}}"
                        HeightRequest="60"
                        Opacity="0.7"
                        Stroke="{AppThemeBinding Light={StaticResource BgDark},
                                      Dark={StaticResource BgLight}}"
                        StrokeThickness="2">
                        <Grid ColumnDefinitions="*, Auto">
                            <Entry
                                x:Name="PassEntry2"
                                IsPassword="True"
                                Placeholder="Confirmar contraseña"
                                PlaceholderColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                                   Dark={StaticResource TitleDark}}"
                                TextChanged="OnPasswordChanged"
                                TextColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                            Dark={StaticResource TitleDark}}"
                                VerticalOptions="Center" />
                            <ImageButton
                                x:Name="BtnEye2"
                                Grid.Column="1"
                                BackgroundColor="Transparent"
                                Clicked="OnShowPasswordClicked"
                                HeightRequest="25"
                                Source="eye_icon.png"
                                WidthRequest="25" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!--  Lista de requisitos de contraseña  -->
                <VerticalStackLayout Margin="5,5,0,0" Spacing="6">

                    <!--  Longitud  -->
                    <HorizontalStackLayout Spacing="8">
                        <BoxView
                            x:Name="ReqLength"
                            BackgroundColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                              Dark={StaticResource TitleDark}}"
                            CornerRadius="6"
                            HeightRequest="12"
                            VerticalOptions="Center"
                            WidthRequest="12" />
                        <Label
                            FontSize="13"
                            Text="Mínimo 10 caracteres"
                            TextColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                        Dark={StaticResource TitleDark}}" />
                    </HorizontalStackLayout>

                    <!--  Minúscula  -->
                    <HorizontalStackLayout Spacing="8">
                        <BoxView
                            x:Name="ReqLower"
                            BackgroundColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                              Dark={StaticResource TitleDark}}"
                            CornerRadius="6"
                            HeightRequest="12"
                            VerticalOptions="Center"
                            WidthRequest="12" />
                        <Label
                            FontSize="13"
                            Text="Al menos una letra minúscula"
                            TextColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                        Dark={StaticResource TitleDark}}" />
                    </HorizontalStackLayout>

                    <!--  Mayúscula  -->
                    <HorizontalStackLayout Spacing="8">
                        <BoxView
                            x:Name="ReqUpper"
                            BackgroundColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                              Dark={StaticResource TitleDark}}"
                            CornerRadius="6"
                            HeightRequest="12"
                            VerticalOptions="Center"
                            WidthRequest="12" />
                        <Label
                            FontSize="13"
                            Text="Al menos una letra mayúscula"
                            TextColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                        Dark={StaticResource TitleDark}}" />
                    </HorizontalStackLayout>

                    <!--  Número  -->
                    <HorizontalStackLayout Spacing="8">
                        <BoxView
                            x:Name="ReqNumber"
                            BackgroundColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                              Dark={StaticResource TitleDark}}"
                            CornerRadius="6"
                            HeightRequest="12"
                            VerticalOptions="Center"
                            WidthRequest="12" />
                        <Label
                            FontSize="13"
                            Text="Al menos un número"
                            TextColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                        Dark={StaticResource TitleDark}}" />
                    </HorizontalStackLayout>

                    <!--  Símbolo  -->
                    <HorizontalStackLayout Spacing="8">
                        <BoxView
                            x:Name="ReqSymbol"
                            BackgroundColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                              Dark={StaticResource TitleDark}}"
                            CornerRadius="6"
                            HeightRequest="12"
                            VerticalOptions="Center"
                            WidthRequest="12" />
                        <Label
                            FontSize="13"
                            Text="Al menos un símbolo"
                            TextColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                        Dark={StaticResource TitleDark}}" />
                    </HorizontalStackLayout>

                    <!--  Indicador de coincidencia  -->
                    <HorizontalStackLayout Spacing="8">
                        <BoxView
                            x:Name="ReqMatch"
                            BackgroundColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                              Dark={StaticResource TitleDark}}"
                            CornerRadius="6"
                            HeightRequest="12"
                            VerticalOptions="Center"
                            WidthRequest="12" />
                        <Label
                            FontSize="13"
                            Text="Las contraseñas deben coincidir"
                            TextColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                        Dark={StaticResource TitleDark}}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Margin="0,10,0,0" Spacing="10">
                    <Button
                        BackgroundColor="{AppThemeBinding Light={StaticResource BtnLight},
                                                          Dark={StaticResource BtnDark}}"
                        Clicked="OnRegisterClicked"
                        CornerRadius="10"
                        FontAttributes="Bold"
                        FontSize="16"
                        HeightRequest="55"
                        Text="Registrarse"
                        TextColor="{AppThemeBinding Light={StaticResource TitleDark},
                                                    Dark={StaticResource TitleLight}}" />

                    <Label
                        Margin="0,5"
                        FontSize="12"
                        HorizontalTextAlignment="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Al registrarse, aceptas nuestros " TextColor="{AppThemeBinding Light={StaticResource TitleLight}, Dark={StaticResource TitleDark}}" />

                                <Span
                                    FontAttributes="Bold"
                                    Text="Términos y Condiciones"
                                    TextColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                                Dark={StaticResource TitleDark}}">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OpenTermsAndConditions" />
                                    </Span.GestureRecognizers>
                                </Span>

                                <Span Text=" y la " TextColor="{AppThemeBinding Light={StaticResource TitleLight}, Dark={StaticResource TitleDark}}" />

                                <Span
                                    FontAttributes="Bold"
                                    Text="Política de Privacidad"
                                    TextColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                                Dark={StaticResource TitleDark}}">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OpenPrivacyPolicy" />
                                    </Span.GestureRecognizers>
                                </Span>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>


                <VerticalStackLayout Margin="0,0,0,10">
                    <BoxView
                        Margin="0,10,0,10"
                        BackgroundColor="Gray"
                        HeightRequest="0.5"
                        Opacity="0.3" />
                    <HorizontalStackLayout
                        HorizontalOptions="Center"
                        Spacing="5"
                        VerticalOptions="End">
                        <Label
                            FontSize="15"
                            Text="¿Ya tienes una cuenta?"
                            TextColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                        Dark={StaticResource TitleDark}}"
                            VerticalOptions="Center" />

                        <Button
                            Padding="0"
                            BackgroundColor="Transparent"
                            Clicked="OnLoginClicked"
                            FontAttributes="Bold"
                            FontSize="15"
                            Text="Iniciar sesión"
                            TextColor="{AppThemeBinding Light={StaticResource TitleLight},
                                                        Dark={StaticResource TitleDark}}"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
